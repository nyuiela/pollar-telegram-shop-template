# Pollar publishable key (public by design) — https://dashboard.pollar.xyz
NEXT_PUBLIC_POLLAR_PUBLISHABLE_KEY=pub_testnet_xxxxxxxxxxxxxxxxxxxx

# Merchant Stellar testnet address that receives USDC checkout payments
NEXT_PUBLIC_MERCHANT_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram bot token from @BotFather — SERVER ONLY, never expose to the client
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here

# Optional: allow browsing the UI outside Telegram during local development
NEXT_PUBLIC_ALLOW_BROWSER_DEV=false
